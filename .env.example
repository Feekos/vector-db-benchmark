# PostgreSQL / pgvectorscale
POSTGRES_USER=user_db_here
POSTGRES_PASSWORD=password_here
POSTGRES_DB=name_db_here
PG_PORT=port_here

# Milvus
MILVUS_PORT=port_here
MILVUS_UI_PORT=ui_port_here

# Qdrant
QDRANT_PORT=port_here
QDRANT_GRPC_PORT=grpc_port_here
# Hugging Face API
HF_TOKEN=your_huggingface_token_here

# Общие настройки
EMBEDDING_MODEL=model_here
EMBEDDING_DIM=model_dimension_here
BATCH_SIZE=batch_size_here
TOP_K=k_means_here
DEVICE=device_here